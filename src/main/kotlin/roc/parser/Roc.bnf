{
  parserClass = "org.roc.community.roc.parser.RocParser"
  elementTypeHolderClass = "org.roc.community.roc.psi.RocTypes"
  elementTypeClass = "org.roc.community.roc.psi.RocElementType"
  tokenTypeClass = "org.roc.community.roc.psi.RocTokenType"
  psiPackage = "org.roc.community.roc.psi"
  psiImplPackage = "org.roc.community.roc.psi.impl"
  psiClassPrefix = "Roc"


  tokens = [
    // brackets & punctuation
    LBRACE = '{'
    RBRACE = '}'
    LPAREN = '('
    NO_SPACE_LPAREN
    RPAREN = ')'
    LBRACK = '['
    RBRACK = ']'
    COMMA = ','

    // operators
    OP_ARROW = '->'
    OP_FAT_ARROW = '=>'
    OP_PIZZA = '|>'
    OP_ASSIGN = '='
    OP_EQUALS = '=='
    OP_COLON = ':'
    OP_COLON_EQUAL = ':='
    OP_DOUBLE_COLON = '::'
    OP_NOT_EQUALS = '!='
    OP_BANG = '!'
    OP_AMPERSAND = '&'
    OP_DOUBLE_QUESTION = '??'
    OP_QUESTION = '?'
    NO_SPACE_OP_QUESTION
    OP_BAR = '|'
    OP_PLUS = '+'
    OP_STAR = '*'
    OP_DOUBLE_SLASH = '//'
    OP_SLASH = '/'
    OP_BACKSLASH
    OP_PERCENT = '%'
    OP_CARET = '^'
    OP_GREATER_THAN_OR_EQ = '>='
    OP_GREATER_THAN = '>'
    OP_LESS_THAN_OR_EQ = '<='
    OP_BACK_ARROW = '<-'
    OP_LESS_THAN = '<'
    OP_BINARY_MINUS
    OP_UNARY_MINUS

    // dot family
    DOT = '.'
    DOUBLE_DOT = '..'
    TRIPLE_DOT = '...'
    DOT_STAR = '.*'
    DOT_INT
    DOT_LOWER_IDENT
    DOT_UPPER_IDENT
    NO_SPACE_DOT_INT
    NO_SPACE_DOT_LOWER_IDENT
    NO_SPACE_DOT_UPPER_IDENT

    // identifiers & literals
    LOWER_IDENT
    UPPER_IDENT
    INT
    FLOAT
    SINGLE_QUOTE
    UNDERSCORE = '_'
    NAMED_UNDERSCORE
    OPAQUE_NAME

    // strings
    STRING_START
    STRING_END
    STRING_PART
    MULTILINE_STRING_START
    OPEN_STRING_INTERPOLATION
    CLOSE_STRING_INTERPOLATION

    // trivia
    COMMENT

    // keywords (and/or are operators in Roc but kept as named tokens)
    KW_AND = 'and'
    KW_APP = 'app'
    KW_AS = 'as'
    KW_CRASH = 'crash'
    KW_DBG = 'dbg'
    KW_ELSE = 'else'
    KW_EXPECT = 'expect'
    KW_EXPOSES = 'exposes'
    KW_EXPOSING = 'exposing'
    KW_FOR = 'for'
    KW_GENERATES = 'generates'
    KW_HAS = 'has'
    KW_HOSTED = 'hosted'
    KW_IF = 'if'
    KW_IMPLEMENTS = 'implements'
    KW_IMPORT = 'import'
    KW_IMPORTS = 'imports'
    KW_IN = 'in'
    KW_INTERFACE = 'interface'
    KW_MATCH = 'match'
    KW_MODULE = 'module'
    KW_OR = 'or'
    KW_PACKAGE = 'package'
    KW_PACKAGES = 'packages'
    KW_PLATFORM = 'platform'
    KW_PROVIDES = 'provides'
    KW_REQUIRES = 'requires'
    KW_RETURN = 'return'
    KW_TARGETS = 'targets'
    KW_VAR = 'var'
    KW_WHERE = 'where'
    KW_WHILE = 'while'
    KW_WITH = 'with'
    KW_BREAK = 'break'
  ]

}

root ::= header | throwaway
private throwaway ::=
      LBRACE | RBRACE | LPAREN | NO_SPACE_LPAREN | RPAREN | LBRACK | RBRACK | COMMA
    | OP_ARROW | OP_FAT_ARROW | OP_PIZZA | OP_ASSIGN | OP_EQUALS | OP_COLON
    | OP_COLON_EQUAL | OP_DOUBLE_COLON | OP_NOT_EQUALS | OP_BANG | OP_AMPERSAND
    | OP_DOUBLE_QUESTION | OP_QUESTION | NO_SPACE_OP_QUESTION | OP_BAR | OP_PLUS
    | OP_STAR | OP_DOUBLE_SLASH | OP_SLASH | OP_BACKSLASH | OP_PERCENT | OP_CARET
    | OP_GREATER_THAN_OR_EQ | OP_GREATER_THAN | OP_LESS_THAN_OR_EQ | OP_BACK_ARROW
    | OP_LESS_THAN | OP_BINARY_MINUS | OP_UNARY_MINUS
    | DOT | DOUBLE_DOT | TRIPLE_DOT | DOT_STAR | DOT_INT | DOT_LOWER_IDENT
    | DOT_UPPER_IDENT | NO_SPACE_DOT_INT | NO_SPACE_DOT_LOWER_IDENT
    | NO_SPACE_DOT_UPPER_IDENT
    | LOWER_IDENT | UPPER_IDENT | INT | FLOAT | SINGLE_QUOTE | UNDERSCORE
    | NAMED_UNDERSCORE | OPAQUE_NAME
    | STRING_START | STRING_END | STRING_PART | MULTILINE_STRING_START
    | OPEN_STRING_INTERPOLATION | CLOSE_STRING_INTERPOLATION
    | COMMENT


// == headers ================================================
// NOTE: `platform` is intentionally absent — its `requires { ... }` block
// contains full type annotations, which need a type-annotation grammar we
// haven't built yet. Its decoded grammar is recorded at the bottom of this
// file; add `| platformHeader` once `typeAnno` lands.
header ::= appHeader | moduleHeader | packageHeader | hostedHeader

appHeader     ::= KW_APP provides packages
moduleHeader  ::= KW_MODULE exposes
packageHeader ::= KW_PACKAGE exposes packages
hostedHeader  ::= KW_HOSTED exposes

provides ::= exposedList
exposes  ::= exposedList
private exposedList ::= LBRACK (exposedItem (COMMA exposedItem)* COMMA?)? RBRACK

exposedItem ::= LOWER_IDENT (KW_AS LOWER_IDENT)?
              | UPPER_IDENT (KW_AS UPPER_IDENT | DOT_STAR)?

// The brace-delimited packages block: `{ name: "path", pf: platform "path" }`
packages     ::= LBRACE (packageEntry (COMMA packageEntry)* COMMA?)? RBRACE
packageEntry ::= LOWER_IDENT OP_COLON KW_PLATFORM? string

string ::= STRING_START stringElement* STRING_END
private stringElement ::= STRING_PART | stringInterpolation
stringInterpolation ::= OPEN_STRING_INTERPOLATION CLOSE_STRING_INTERPOLATION // M1 stub: no inner expr yet

// == DEFERRED: platform header ==============================
// Blocked on the type-annotation grammar (parseTypeAnno in the Zig reference,
// roc-lang/src/parse/Parser.zig). Decoded here so it's ready to wire up:
//
//   platformHeader ::= PLATFORM string
//                      REQUIRES requiresBlock
//                      EXPOSES  exposedList
//                      PACKAGES packages
//                      PROVIDES recordFieldBlock      // '{' field,* '}'
//                      targetsSection?
//
//   requiresBlock ::= LBRACE (requiresEntry (COMMA requiresEntry)* COMMA?)? RBRACE
//     requiresEntry ::= (LBRACK forClauseAlias (COMMA forClauseAlias)* RBRACK FOR)?
//                       LOWER_IDENT OP_COLON typeAnno     // <-- needs typeAnno
//     forClauseAlias ::= UPPER_IDENT OP_COLON LOWER_IDENT
//     (legacy `requires {} { ... }` empty-rigids form also exists)
//
//   targetsSection is optional and non-trivial (see parseTargetsSection).
//
// Implement `typeAnno` first (ty_var / ty / apply / fn with -> and => /
// tuples / records), then this header is straightforward.
// Ideas:
//  - Make a Identifier superclass for LOWER_IDENT, NO_SPACE_DOT_UPPER_IDENT etc.
{
  parserClass = "org.roc.community.roc.parser.RocParser"
  elementTypeHolderClass = "org.roc.community.roc.psi.RocTypes"
  elementTypeClass = "org.roc.community.roc.psi.RocElementType"
  tokenTypeClass = "org.roc.community.roc.psi.RocTokenType"
  psiPackage = "org.roc.community.roc.psi"
  psiImplPackage = "org.roc.community.roc.psi.impl"
  psiClassPrefix = "Roc"

  // Every alternative of the `expr` engine root extends it (→ a shared RocExpr base), which
  // is how Grammar-Kit groups the expression rules for its left-recursion/priority engine.
  // Full-matches rule names: `*Literal`, `string`, `*Expr` — not recordExprExt/…Field/…Pattern.
  extends("string|.*Literal|.*Expr")=expr


  tokens = [
    // brackets & punctuation
    LBRACE = '{'
    RBRACE = '}'
    LPAREN = '('
    NO_SPACE_LPAREN
    RPAREN = ')'
    LBRACK = '['
    RBRACK = ']'
    COMMA = ','

    // operators
    OP_ARROW = '->'
    OP_FAT_ARROW = '=>'
    OP_PIZZA = '|>'
    OP_ASSIGN = '='
    OP_EQUALS = '=='
    OP_COLON = ':'
    OP_COLON_EQUAL = ':='
    OP_DOUBLE_COLON = '::'
    OP_NOT_EQUALS = '!='
    OP_BANG = '!'
    OP_AMPERSAND = '&'
    OP_DOUBLE_QUESTION = '??'
    OP_QUESTION = '?'
    NO_SPACE_OP_QUESTION
    OP_BAR = '|'
    OP_PLUS = '+'
    OP_STAR = '*'
    OP_DOUBLE_SLASH = '//'
    OP_SLASH = '/'
    OP_BACKSLASH
    OP_PERCENT = '%'
    OP_CARET = '^'
    OP_GREATER_THAN_OR_EQ = '>='
    OP_GREATER_THAN = '>'
    OP_LESS_THAN_OR_EQ = '<='
    OP_BACK_ARROW = '<-'
    OP_LESS_THAN = '<'
    OP_BINARY_MINUS
    OP_UNARY_MINUS

    // dot family
    DOT = '.'
    DOUBLE_DOT = '..'
    TRIPLE_DOT = '...'
    DOT_STAR = '.*'
    DOT_INT
    DOT_LOWER_IDENT
    DOT_UPPER_IDENT
    NO_SPACE_DOT_INT
    NO_SPACE_DOT_LOWER_IDENT
    NO_SPACE_DOT_UPPER_IDENT

    // identifiers & literals
    LOWER_IDENT
    UPPER_IDENT
    INT
    FLOAT
    SINGLE_QUOTE
    UNDERSCORE = '_'
    NAMED_UNDERSCORE
    OPAQUE_NAME

    // strings
    STRING_START
    STRING_END
    STRING_PART
    MULTILINE_STRING_START
    OPEN_STRING_INTERPOLATION
    CLOSE_STRING_INTERPOLATION

    // trivia
    COMMENT

    // keywords (and/or are operators in Roc but kept as named tokens)
    KW_AND = 'and'
    KW_APP = 'app'
    KW_AS = 'as'
    KW_CRASH = 'crash'
    KW_DBG = 'dbg'
    KW_ELSE = 'else'
    KW_EXPECT = 'expect'
    KW_EXPOSES = 'exposes'
    KW_EXPOSING = 'exposing'
    KW_FOR = 'for'
    KW_GENERATES = 'generates'
    KW_HAS = 'has'
    KW_HOSTED = 'hosted'
    KW_IF = 'if'
    KW_IMPLEMENTS = 'implements'
    KW_IMPORT = 'import'
    KW_IMPORTS = 'imports'
    KW_IN = 'in'
    KW_INTERFACE = 'interface'
    KW_MATCH = 'match'
    KW_MODULE = 'module'
    KW_OR = 'or'
    KW_PACKAGE = 'package'
    KW_PACKAGES = 'packages'
    KW_PLATFORM = 'platform'
    KW_PROVIDES = 'provides'
    KW_REQUIRES = 'requires'
    KW_RETURN = 'return'
    KW_TARGETS = 'targets'
    KW_VAR = 'var'
    KW_WHERE = 'where'
    KW_WHILE = 'while'
    KW_WITH = 'with'
    KW_BREAK = 'break'
  ]

}

root ::= header? statement*

// `statement` (top level) and `blockStmt` (in a block) both mirror the reference's single parseStmt;
// the top_level/in_body differences (import top-level-only, var in-body-only, type decls) are
// later-phase context checks. The trailing `expr` is the final / bare-expression statement
// (Parser.zig 2140) — a standalone `dbg y`, a tag, a call, etc. Each decl/anno arm rolls back when
// its committing `=`/`:` is absent, so `expr` is reached only for a genuine bare expression.
private statement ::= importStatement | keywordStmt | valueAnnotation | typeDecl | varDecl | valueDecl | expr

// Lexer-only tokens — the lexer emits these but no rule consumes them: `COMMENT` is trivia
// (RocParserDefinition.getCommentTokens); `@`-opaque names and a lone `\` are tokenizer-only in the
// reference TOO (Parser.zig never reads OpaqueName/OpBackslash — they'd be malformed there), so a
// rule would invent syntax. This rule is NEVER reached from `root`; it exists only so Grammar-Kit
// keeps generating their RocTypes constants (a no-text token is pruned unless some rule names it),
// which the generated lexer and RocTokenSets.COMMENTS depend on. (MULTILINE_STRING_START dropped from
// this list in M5 — now anchored by the real multilineStringExpr rule.)
private lexerOnlyTokens ::= COMMENT | OPAQUE_NAME | OP_BACKSLASH


// == headers ================================================
// Dispatched on a distinct leading keyword (app/module/package/hosted/platform),
// so the alternatives are first-token-disjoint and order is irrelevant
// platform header is difficult and uses many other primitives is at the bottom of this file
header ::= appHeader | moduleHeader | packageHeader | hostedHeader | platformHeader

appHeader     ::= KW_APP provides packages
moduleHeader  ::= KW_MODULE exposes
packageHeader ::= KW_PACKAGE exposes packages
hostedHeader  ::= KW_HOSTED exposes

provides ::= exposedList
exposes  ::= exposedList
private exposedList ::= LBRACK (exposedItem (COMMA exposedItem)* COMMA?)? RBRACK

exposedItem ::= LOWER_IDENT (KW_AS LOWER_IDENT)?
              | UPPER_IDENT (KW_AS UPPER_IDENT | DOT_STAR)?

// The brace-delimited packages block: `{ name: "path", pf: platform "path" }`
packages     ::= LBRACE (packageEntry (COMMA packageEntry)* COMMA?)? RBRACE
packageEntry ::= LOWER_IDENT OP_COLON KW_PLATFORM? string

string ::= STRING_START stringElement* STRING_END
private stringElement ::= STRING_PART | stringInterpolation
// `${ expr }` — inner expr stops at CLOSE_STRING_INTERPOLATION (a distinct token, not RBRACE).
// In a pattern-position string, interpolation is a later-phase reject, not a grammar concern.
stringInterpolation ::= OPEN_STRING_INTERPOLATION expr CLOSE_STRING_INTERPOLATION

// Line-oriented multiline string (Parser.zig parseMultiLineStringExpr 3437). One MULTILINE_STRING_START
// per line — from `"""` or the Zig-style `\\` prefix — with no close token; the EOL between lines is
// whitespace trivia, so consecutive line-starts stitch into one node here. Named *Expr to join the
// expression engine; expr-only (multiline-in-pattern is a later-phase reject, like interpolation).
multilineStringExpr ::= MULTILINE_STRING_START multilineStringPart*
private multilineStringPart ::= STRING_PART | stringInterpolation | MULTILINE_STRING_START

// == imports ================================================
// Two forms, dispatched on the token after `import`:
//   module import:  import pf.Stdout | import Json.Core | import json.Json.Utf8
//                          ... as Out | ... exposing [line!, write]
//   file import:    import "data.txt" as data : Str
importStatement ::= KW_IMPORT (fileImport | moduleImport)

private moduleImport ::= moduleName importAlias? importExposing?
moduleName ::= UPPER_IDENT  (NO_SPACE_DOT_UPPER_IDENT | DOT_UPPER_IDENT)*
             | LOWER_IDENT (NO_SPACE_DOT_UPPER_IDENT | DOT_UPPER_IDENT)+
importAlias    ::= KW_AS UPPER_IDENT
importExposing ::= KW_EXPOSING exposedList        // reuses the header's exposedList

// `import "path" as name : <type>`. Roc restricts the type to Str / List(U8),
// but that's a semantic check; syntactically any typeAnno is accepted here.
private fileImport ::= string KW_AS LOWER_IDENT OP_COLON typeAnno

// == type-declaration statements ============================
// Optional leading `var` is the reference's is_var flag (Parser.zig 1878); `var x : T` lands here,
// `x : T` without it. The `var` + plain-ident shape (not NAMED_UNDERSCORE) is a later-phase check.
valueAnnotation ::= KW_VAR? (LOWER_IDENT | NAMED_UNDERSCORE) OP_COLON typeAnno whereClause?

// `Name(a) : T` (alias) | `Name(a) := T` (nominal) | `Name(a) :: T` (opaque).

// Params are PARENTHESISED type vars (parseTypeIdent) — the old space-separated
typeDecl       ::= typeHeader (OP_COLON | OP_COLON_EQUAL | OP_DOUBLE_COLON) typeAnno whereClause? associatedBlock?

// Associated items `.{ … }` on a nominal/opaque decl (Parser.zig 2047). `.{` is DOT + LBRACE (the lexer
// has no combined token; the bare `.` is plain DOT because `{` is not an ident char). Holds the
// reference's "associated types and values" — annotations, value decls, nested type decls. Items are
// private so VALUE_ANNOTATION / VALUE_DECL / TYPE_DECL attach directly under ASSOCIATED_BLOCK (like
// blockStmt), and reuse the existing decl-vs-anno rollback ordering. Semantic-only rules deferred to a
// later phase: alias may not carry a block (type_alias_cannot_have_associated); the last item may not be
// a bare expr (nominal_associated_cannot_have_final_expression) — hence no `expr` arm here.
associatedBlock ::= DOT LBRACE associatedItem* RBRACE
private associatedItem ::= valueAnnotation | typeDecl | valueDecl

typeHeader     ::= UPPER_IDENT typeHeaderArgs?
typeHeaderArgs ::= (NO_SPACE_LPAREN | LPAREN) (typeParam (COMMA typeParam)* COMMA?)? RPAREN
// A type parameter is the DECLARATION site of a type variable (uses appear as
// `typeReference`). Kept public so a later resolution phase can hang find-usages /
// rename / unused-param on it (PsiNamedElement) without re-shaping the grammar.
typeParam ::= LOWER_IDENT | NAMED_UNDERSCORE | UNDERSCORE

// `where [ clause, … ]` abilities constraints. A clause is a method
// (`a.method : Type`) or an alias (`a.Alias`, no colon). Method types reuse `typeAnno`
// (commonly a comma-arg function, e.g. `a, a -> Bool`). The reference rejects an empty
// `where []`, so at least one clause is required.
whereClause ::= KW_WHERE LBRACK whereClauseItem (COMMA whereClauseItem)* COMMA? RBRACK
private whereClauseItem ::= whereMethod | whereAlias
whereMethod ::= LOWER_IDENT (NO_SPACE_DOT_LOWER_IDENT | DOT_LOWER_IDENT) OP_COLON typeAnno
whereAlias  ::= LOWER_IDENT (NO_SPACE_DOT_UPPER_IDENT | DOT_UPPER_IDENT)

// == declarations ===========================================
// Value / destructure declaration: `x = e`, `{a, b} = e`, `(x, y) = e` — the reference's `.decl`
// (parseStmtByType 1907 / 1975 / 2111).
valueDecl ::= patternNoAlts OP_ASSIGN expr

// `var x = e` — dedicated mutable-binding statement (.var, Parser.zig 1891). `var` is NOT a pattern
// in Roc (single ident only, 1868) — hence its own rule, not a patternPrimary. `var x : T` is a
// flagged annotation (see valueAnnotation). In-body-only / single-ident limits are later-phase checks.
varDecl ::= KW_VAR LOWER_IDENT OP_ASSIGN expr

// == keyword statements =====================================
// parseStmtByType (Parser.zig 1791-1906), shared by `statement` and `blockStmt`. Context limits
// (var in-body, import top-level) are a later-phase check, not grammar. `var` waits for the
// valueDecl rework; `dbg`/`for` are expressions (see dbgExpr/forExpr).
private keywordStmt ::= expectStmt | crashStmt | returnStmt | whileStmt | breakStmt
expectStmt ::= KW_EXPECT expr
crashStmt  ::= KW_CRASH  expr
returnStmt ::= KW_RETURN expr       // statement-only; in expr position the reference malforms it (3137)
whileStmt  ::= KW_WHILE  expr expr  // cond, body
breakStmt  ::= KW_BREAK

// == patterns ===============================================
private pattern       ::= alternativesPattern | asPattern | patternPrimary
private patternNoAlts ::= asPattern | patternPrimary

// `a | b | c`
alternativesPattern ::= patternPrimary (OP_BAR patternPrimary)+
// postfix `p as name` — only a node when `as` is present.
asPattern ::= patternPrimary KW_AS LOWER_IDENT

// All first-sets are disjoint, so ordering is irrelevant and there is no
// intra-primary backtracking.
private patternPrimary ::= underscorePattern
                         | identPattern
                         | tagPattern
                         | literalPattern
                         | string
                         | listPattern
                         | recordPattern
                         | tuplePattern

identPattern      ::= LOWER_IDENT | NAMED_UNDERSCORE   // both are `.ident` in Roc
underscorePattern ::= UNDERSCORE                       // `_`
literalPattern    ::= INT | FLOAT | SINGLE_QUOTE       // string literal reuses `string`

// `Ok`, `Json.Ok`, `Pair(x, y)`. Qualifier chain = lexer dotted-upper tokens
tagPattern     ::= UPPER_IDENT NO_SPACE_DOT_UPPER_IDENT* tagPatternArgs?
tagPatternArgs ::= NO_SPACE_LPAREN (pattern (COMMA pattern)* COMMA?)? RPAREN

// `[a, b]`, `[1, 2, .. as rest]`, `[..]`. List rest is `.. as name` (new syntax).
listPattern             ::= LBRACK (listPatternElem (COMMA listPatternElem)* COMMA?)? RBRACK
private listPatternElem ::= listRestPattern | pattern
listRestPattern         ::= DOUBLE_DOT (KW_AS LOWER_IDENT)?

// `{ name, age }`, `{ name: n }`, `{ x, ..rest }`. NB record rest is `..name`
// directly (no `as`), unlike list rest.
recordPattern      ::= LBRACE (recordPatternField (COMMA recordPatternField)* COMMA?)? RBRACE
recordPatternField ::= DOUBLE_DOT LOWER_IDENT?
                     | LOWER_IDENT (OP_COLON pattern)?

// `(a, b)`, `(a)`. A standalone '(' may be spaced or no-space.
tuplePattern ::= (NO_SPACE_LPAREN | LPAREN) (pattern (COMMA pattern)* COMMA?)? RPAREN

// == type annotations =======================================
// Faithful to parseTypeAnno in the Zig reference (roc-lang/src/parse/Parser.zig).
//
// The arrow function is the lowest-precedence type; its argument list may be a
// bare comma list (`Str, Str -> Str`). `functionType` REQUIRES a trailing arrow,
// so for a plain type it backtracks to `primaryType`. That same backtracking is
// what lets a record field type stop at the next field (`{ a: Str, b: U64 }`)
// and an apply arg stop at the next arg (`Dict(Str, List(U64))`) — the comma
// list is only kept when an arrow actually follows.
//
// KNOWN LIMITATION: an unparenthesized arrow used as a NON-final argument inside
// `( )` / apply args (e.g. `Dict(k, v -> w)`) is grabbed as one comma-grouped
// function rather than two args. Roc flips comma/arrow precedence per-context via
// a lookahead flag; we don't yet. Rare in practice — parenthesize for now.
// typeAnno / primaryType are dispatch-only (private) so the concrete type node
// (functionType, typeReference, recordType, …) attaches directly, with no
// redundant wrapper — same idea as `header`.
private typeAnno ::= functionType | primaryType

functionType ::= typeFnArgs (OP_ARROW | OP_FAT_ARROW) typeAnno
private typeFnArgs ::= primaryType (COMMA primaryType)*

private primaryType ::= typeReference
                      | tupleType
                      | recordType
                      | tagUnionType
                      | inferredType
                      | inferredTypeVar

// Str, Bool, Foo.Bar, json.Mod.Type, List(a), Dict(k, v).
// Qualification is built from the no-space dotted tokens the lexer emits, e.g.
// `Json.Decoder` -> UPPER_IDENT NO_SPACE_DOT_UPPER_IDENT. Application requires a
// no-space '(' (NO_SPACE_LPAREN), matching `List(a)` but not `List (a)`.
typeReference ::= typeName typeArguments?
private typeName ::= (UPPER_IDENT | LOWER_IDENT) qualifierSegment*
private qualifierSegment ::= NO_SPACE_DOT_UPPER_IDENT | NO_SPACE_DOT_LOWER_IDENT
typeArguments ::= NO_SPACE_LPAREN (typeAnno (COMMA typeAnno)* COMMA?)? RPAREN

// (a), (a, b), (a -> b). A standalone '(' may be no-space or spaced.
tupleType ::= (NO_SPACE_LPAREN | LPAREN) (typeAnno (COMMA typeAnno)* COMMA?)? RPAREN

// { name: Type, ..ext } — `..` / `..rest` extension must be last.
recordType ::= LBRACE recordTypeBody? RBRACE
private recordTypeBody ::= recordTypeField (COMMA recordTypeField)* (COMMA recordTypeExt)? COMMA?
                         | recordTypeExt
recordTypeField ::= LOWER_IDENT OP_COLON typeAnno
recordTypeExt ::= DOUBLE_DOT (LOWER_IDENT | NAMED_UNDERSCORE)?

// [Ok(a), Err(b), ..ext] — open-union extension must be last.
tagUnionType ::= LBRACK tagUnionBody? RBRACK
private tagUnionBody ::= tagUnionMember (COMMA tagUnionMember)* (COMMA tagUnionExt)? COMMA?
                       | tagUnionExt
tagUnionMember ::= UPPER_IDENT typeArguments?
tagUnionExt ::= DOUBLE_DOT (LOWER_IDENT | NAMED_UNDERSCORE)?

inferredType    ::= UNDERSCORE        // _
inferredTypeVar ::= NAMED_UNDERSCORE  // _name

// == expressions (M4) =======================================
// parseExprWithBp in the Zig reference, via Grammar-Kit's expression engine. `expr` is the
// engine root — it produces NO node of its own; the matched alternative produces its node, so
// existing atom/collection trees are unchanged. Alternatives are listed LOOSEST→TIGHTEST
// (top→bottom), which is how the engine assigns precedence: the binary ladder (M4d) loosest,
// then unary, then the left-recursive postfix suffixes (M4c), then the primary atoms (tightest).
// Binary precedence/associativity mirror getTokenBP (Parser.zig 4321); see the ladder below.
expr ::= orExpr
       | andExpr
       | comparisonExpr
       | binQuestionExpr      // binary `?`
       | coalesceExpr         // `??`
       | addExpr              // `+` `-`
       | modExpr              // `%`
       | intDivExpr           // `//`
       | divExpr              // `/`
       | mulExpr              // `*`
       | unaryExpr            // prefix `-` `!`
       | callExpr
       | methodCallExpr
       | fieldAccessExpr
       | tupleAccessExpr
       | arrowCallExpr        // postfix `->` arrow-call (M5)
       | questionSuffixExpr   // postfix `?` (NO_SPACE_OP_QUESTION)
       | typedIntLiteral | typedFloatLiteral | intLiteral | floatLiteral | charLiteral | string | multilineStringExpr
       | qualifiedNameExpr | tagExpr | identExpr
       | ellipsisExpr         // `...`
       | ifExpr | matchExpr | forExpr | lambdaExpr | dbgExpr   // control flow (M4e/M4f)
       | listExpr | tupleExpr | recordExpr | blockExpr   // recordExpr FIRST (see blockExpr)

// -- binary-operator ladder (M4d) ---------------------------
// All binary operators share ONE BINARY_EXPR node (faithful to the reference's single bin_op);
// the operator token distinguishes them. The `fake` base generates the RocBinaryExpr PSI
// interface (+ left/right accessors) but no parser; each real rule reuses its element type via
// `elementType`. Precedence is set by each rule's position in `expr` above (ascending
// getTokenBP). `and`/`or` are right-assoc (reference left-bp > right-bp); the rest left
// (engine default). `extends=binaryExpr` overrides the global `extends(...)=expr`, but
// `binaryExpr` itself matches `.*Expr` so every rule still extends the `expr` root.
fake binaryExpr ::= expr binaryOp expr { methods=[ left="expr[0]" right="expr[1]" ] }
private binaryOp ::= OP_STAR | OP_SLASH | OP_DOUBLE_SLASH | OP_PERCENT | OP_PLUS
                   | OP_BINARY_MINUS | OP_DOUBLE_QUESTION | OP_QUESTION | OP_EQUALS
                   | OP_NOT_EQUALS | OP_LESS_THAN | OP_GREATER_THAN | OP_LESS_THAN_OR_EQ
                   | OP_GREATER_THAN_OR_EQ | KW_AND | KW_OR

orExpr          ::= expr KW_OR  expr { extends=binaryExpr elementType=binaryExpr rightAssociative=true }
andExpr         ::= expr KW_AND expr { extends=binaryExpr elementType=binaryExpr rightAssociative=true }
// Comparisons collapse into ONE non-associative tier: the reference's 6 distinct levels only
// diverge on CHAINED comparisons, which are a semantic error. Engine default left-assoc here;
// the non-associativity rule is a later semantic check, not grammar.
comparisonExpr  ::= expr (OP_EQUALS | OP_NOT_EQUALS | OP_LESS_THAN | OP_GREATER_THAN
                          | OP_LESS_THAN_OR_EQ | OP_GREATER_THAN_OR_EQ) expr { extends=binaryExpr elementType=binaryExpr }
binQuestionExpr ::= expr OP_QUESTION         expr { extends=binaryExpr elementType=binaryExpr }
coalesceExpr    ::= expr OP_DOUBLE_QUESTION  expr { extends=binaryExpr elementType=binaryExpr }
addExpr         ::= expr (OP_PLUS | OP_BINARY_MINUS) expr { extends=binaryExpr elementType=binaryExpr }
modExpr         ::= expr OP_PERCENT      expr { extends=binaryExpr elementType=binaryExpr }
intDivExpr      ::= expr OP_DOUBLE_SLASH expr { extends=binaryExpr elementType=binaryExpr }
divExpr         ::= expr OP_SLASH        expr { extends=binaryExpr elementType=binaryExpr }
mulExpr         ::= expr OP_STAR         expr { extends=binaryExpr elementType=binaryExpr }

// Prefix unary — distinct tokens (OP_UNARY_MINUS / OP_BANG, not the binary OP_BINARY_MINUS),
// one UNARY_EXPR node. Binds tighter than all binary, looser than the suffixes (`-a.b` = `-(a.b)`).
unaryExpr ::= (OP_UNARY_MINUS | OP_BANG) expr

// Postfix application/access — each wraps the preceding `expr`. Application needs a no-space
// `(` (NO_SPACE_LPAREN); the dot before field/method/tuple access may be spaced, so method
// chains can break across lines (reference suffix loop accepts both dot forms, Parser.zig 3146).
callExpr        ::= expr callArgs
// UFCS method call (`x.f(a)` passes `x` as an arg) — a distinct node from call-of-field-access,
// faithful to the reference's dedicated `method_call` (Parser.zig 3223). Must precede
// fieldAccessExpr: they share the `expr .lowerIdent` prefix, this one also requires the `(`.
methodCallExpr  ::= expr (NO_SPACE_DOT_LOWER_IDENT | DOT_LOWER_IDENT) callArgs
fieldAccessExpr ::= expr (NO_SPACE_DOT_LOWER_IDENT | DOT_LOWER_IDENT)
tupleAccessExpr ::= expr (NO_SPACE_DOT_INT | DOT_INT)
// Postfix `?` (try-propagation) — the NO-space token; suffix tier, left-recursive like the
// access suffixes above. Distinct from the spaced binary `?`/`??` (OP_QUESTION/OP_DOUBLE_QUESTION).
questionSuffixExpr ::= expr NO_SPACE_OP_QUESTION
// UFCS static-dispatch arrow `recv->method(args)` / `recv->Tag` / `recv->(|x| body)(extra)`. A
// postfix in the reference's dot-loop (Parser.zig 3146), tightest tier, left-assoc. The target is a
// name or paren-expr plus zero+ call-arg applications (parseExprApplicationSuffix 3188), NOT a full
// binary expr — so `a->b + c` is `(a->b) + c`. Reusing engine primaries from this private rule works
// the same way patternPrimary reuses `string`. RHS-must-be-callable is a later-phase check.
arrowCallExpr ::= expr OP_ARROW arrowCallTarget
private arrowCallTarget ::= (qualifiedNameExpr | tagExpr | identExpr | tupleExpr) callArgs*
private callArgs ::= NO_SPACE_LPAREN (expr (COMMA expr)* COMMA?)? RPAREN

// Separate nodes (not one literalExpr) to mirror the reference's .int / .frac / single-quote
// — keeps later type-inference/inspections a direct match. Multiline is multilineStringExpr;
// typed numeric suffixes are the two rules below.
// Typed numeric literal `5.U8` / `3.0.F64` — the reference's typed_int / typed_frac (Parser.zig 2790,
// 2831): an INT/FLOAT immediately followed (no space) by NO_SPACE_DOT_UPPER_IDENT. A primary-level form
// bound to a bare numeric token, NOT a general postfix (so `(1+2).U8` is not this). Listed before the
// plain literals in `expr` so the suffixed form wins when `.Type` is present; falls through to
// intLiteral for a bare `5`. Distinct nodes mirror the reference's typed_int / typed_frac.
typedIntLiteral   ::= INT   NO_SPACE_DOT_UPPER_IDENT
typedFloatLiteral ::= FLOAT NO_SPACE_DOT_UPPER_IDENT
intLiteral   ::= INT
floatLiteral ::= FLOAT
charLiteral  ::= SINGLE_QUOTE

// Bare lower-start name. NOT qualified: the reference only chains upper-start names
// (parseQualificationChain is called only from the `.UpperIdent` arm), so `json.foo` is this
// bare ident plus a `.foo` field-access suffix, NOT a qualified name.
identExpr ::= LOWER_IDENT | NAMED_UNDERSCORE

// Upper-start names. A bare `Ok` is a tag; a dotted chain (`Json.Ok`, `Json.decode`,
// `Core.Json.Utf8`) is a single qualified name. We deliberately do NOT split the chain into
// tag-vs-qualified-ident at parse time: Grammar-Kit's `*`/`+` are greedy WITHOUT backtracking,
// so `qualChainSeg* <trailing-dotted-token>` can never match — the loop eats the token the
// trailing match needs (qualChainSeg itself matches that token). Instead the chain is consumed
// greedily in one node, faithful to parseQualificationChain's single pass (Parser.zig 2674);
// the tag-vs-value distinction (final segment upper→tag, lower→qualified value) is a later-phase
// check on the last child token. qualifiedNameExpr precedes tagExpr in `expr` so a chain is
// taken whole here, not as a bare tag + dotted suffix.
qualifiedNameExpr ::= UPPER_IDENT qualChainSeg+
tagExpr           ::= UPPER_IDENT
private qualChainSeg ::= NO_SPACE_DOT_UPPER_IDENT | NO_SPACE_DOT_LOWER_IDENT

// `...` placeholder/ellipsis — a standalone primary expression (Parser.zig 3107 `.TripleDot`),
// NOT a prefix operator.
ellipsisExpr ::= TRIPLE_DOT

// -- control-flow keyword expressions (M4e) -----------------
// Primary-switch arms of parseExprWithBp. All are EXPRESSIONS in Roc (the reference puts
// if/match/for/lambda in parseExprWithBp, not parseStmt), so each matches `.*Expr` and joins the
// engine as a primary via the global extends(...). Their lead tokens (KW_IF/KW_MATCH/KW_FOR/OP_BAR)
// are disjoint from every other primary. Bodies are full `expr`s — in practice a block (a later
// slice), but any expr works: Roc has no juxtaposition application, so adjacent exprs are
// unambiguous (the inner `expr` parses to completion, then the next has no linking operator/suffix).

// No `then` keyword in Roc — the branches are juxtaposed. Missing `else` is the reference's
// statement-form `if_without_else` (Parser.zig 3034); we accept it as an IF_EXPR with no else.
ifExpr ::= KW_IF expr expr (KW_ELSE expr)?

// `match subject { pattern (if guard)? => body, … }`. The braces belong to matchExpr (consumed
// positionally, Parser.zig 3060) — NOT a standalone `{` primary, so no record/block ambiguity.
// Branches optionally comma-separated, trailing comma allowed; the `=>` is OP_FAT_ARROW (the
// reference also tolerates `->` with a diagnostic — left to a later phase). matchBranch is a
// regular node (doesn't match `.*Expr`, stays out of the engine); its pattern allows alternatives.
matchExpr   ::= KW_MATCH expr LBRACE matchBranch (COMMA? matchBranch)* COMMA? RBRACE
matchBranch ::= pattern (KW_IF expr)? OP_FAT_ARROW expr

// Closure `|args| body` — patternNoAlts list (alternatives forbidden) between two bars; `||` (no
// args) allowed (Parser.zig 3012). OP_BAR is a unique lead token (`|>` is the distinct OP_PIZZA,
// and there is no `||` token — logical-or is KW_OR — so `||` lexes as two OP_BAR).
lambdaExpr ::= OP_BAR (patternNoAlts (COMMA patternNoAlts)* COMMA?)? OP_BAR expr

// `for pattern in iterable body` — `for` is an expression in Roc (Parser.zig 3092); pattern is
// alternatives-forbidden. (The platform header's KW_FOR is a header-only position, never reached
// via expr, so there is no conflict.)
forExpr ::= KW_FOR patternNoAlts KW_IN expr expr

// `dbg <expr>` — expression primary (Parser.zig 3084), like forExpr. Also a statement in the ref
// (1842), but the expression form covers both our contexts (RHS, and block stmt via blockStmt's
// `expr` arm). Standalone top-level `dbg y` waits on the top-level bare-expr arm (next slice).
dbgExpr ::= KW_DBG expr

listExpr  ::= LBRACK (expr (COMMA expr)* COMMA?)? RBRACK

// A single `(a)` is built as a 1-tuple, not a grouping node — faithful to parseExprWithBp
// (`// TODO: Parenthesized expressions`) and consistent with tuplePattern.
tupleExpr ::= (NO_SPACE_LPAREN | LPAREN) (expr (COMMA expr)* COMMA?)? RPAREN

// `{`-primary RECORD form. Listed before blockExpr in `expr`; record-first ordering IS the
// record-vs-block split (see blockExpr). Unlike record TYPE/PATTERN, the update extension is a
// PREFIX (ext first), per the `.OpenCurly` arm of parseExprWithBp.
recordExpr ::= LBRACE recordExprBody? RBRACE
private recordExprBody ::= recordExprExt COMMA (recordExprField (COMMA recordExprField)* COMMA?)?
                         | recordExprField (COMMA recordExprField)* COMMA?
recordExprExt   ::= DOUBLE_DOT expr
recordExprField ::= LOWER_IDENT (OP_COLON expr)?

// Record-vs-block split is by ORDER: recordExpr (first in `expr`) commits only on a genuine record
// body and rolls back on a statement token (`=`, `x.y`, `1+2`, a 2nd bare ident), so blocks fall
// here. Matches Parser.zig's `.OpenCurly` arm (2909-3010) except `{ ident }` — reference: block
// returning `ident`; us: shorthand record (type-level only, reversible via a later `=`-lookahead
// predicate). `+` (non-empty) leaves `{}` to recordExpr, the reference's empty record.
blockExpr ::= LBRACE blockStmt+ RBRACE

// Block form of `statement` (see its comment); the concrete node attaches directly under BLOCK_EXPR.
private blockStmt ::= keywordStmt | valueAnnotation | varDecl | valueDecl | expr

// == platform header ========================================
// Shape: platform "name" requires {…} exposes […] packages {…} provides {…} [targets:…]
platformHeader ::= KW_PLATFORM string
                   KW_REQUIRES platformRequires
                   KW_EXPOSES  exposes
                   KW_PACKAGES packages
                   KW_PROVIDES platformProvides
                   platformTargets?

platformRequires ::= LBRACE RBRACE LBRACE requiresEntries? RBRACE
                   | LBRACE requiresEntries? RBRACE
private requiresEntries ::= requiresEntry (COMMA requiresEntry)* COMMA?
// `main! : Type`, optionally prefixed by a for-clause `[Model : model] for`.
requiresEntry     ::= requiresForClause? LOWER_IDENT OP_COLON typeAnno
requiresForClause ::= LBRACK requiresForAlias (COMMA requiresForAlias)* RBRACK KW_FOR
requiresForAlias  ::= UPPER_IDENT OP_COLON LOWER_IDENT

// `provides { name: <expr>, … }` — record-style, unlike the app header's `[ … ]` provides.
// Values are expressions (a string path in practice).
platformProvides      ::= LBRACE (platformProvidesField (COMMA platformProvidesField)* COMMA?)? RBRACE
platformProvidesField ::= LOWER_IDENT (OP_COLON expr)?

// optional `targets: { files: "…", exe: { x64mac: ["libhost.a", app], … }, … }`.
// A target field's value is a string (files path) or a link-type block; a link
// entry maps a triple name to a bracketed file list of strings / idents / `app`.
platformTargets ::= KW_TARGETS OP_COLON LBRACE (targetsField (COMMA targetsField)* COMMA?)? RBRACE
targetsField    ::= LOWER_IDENT OP_COLON (string | targetLinkType)
targetLinkType  ::= LBRACE (targetLinkEntry (COMMA targetLinkEntry)* COMMA?)? RBRACE
targetLinkEntry ::= LOWER_IDENT OP_COLON LBRACK (targetFile (COMMA targetFile)* COMMA?)? RBRACK
targetFile      ::= string | LOWER_IDENT | KW_APP
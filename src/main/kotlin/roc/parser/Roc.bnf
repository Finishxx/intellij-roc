// Ideas:
//  - Make a Identifier superclass for LOWER_IDENT, NO_SPACE_DOT_UPPER_IDENT etc.
{
  parserClass = "org.roc.community.roc.parser.RocParser"
  elementTypeHolderClass = "org.roc.community.roc.psi.RocTypes"
  elementTypeClass = "org.roc.community.roc.psi.RocElementType"
  tokenTypeClass = "org.roc.community.roc.psi.RocTokenType"
  psiPackage = "org.roc.community.roc.psi"
  psiImplPackage = "org.roc.community.roc.psi.impl"
  psiClassPrefix = "Roc"


  tokens = [
    // brackets & punctuation
    LBRACE = '{'
    RBRACE = '}'
    LPAREN = '('
    NO_SPACE_LPAREN
    RPAREN = ')'
    LBRACK = '['
    RBRACK = ']'
    COMMA = ','

    // operators
    OP_ARROW = '->'
    OP_FAT_ARROW = '=>'
    OP_PIZZA = '|>'
    OP_ASSIGN = '='
    OP_EQUALS = '=='
    OP_COLON = ':'
    OP_COLON_EQUAL = ':='
    OP_DOUBLE_COLON = '::'
    OP_NOT_EQUALS = '!='
    OP_BANG = '!'
    OP_AMPERSAND = '&'
    OP_DOUBLE_QUESTION = '??'
    OP_QUESTION = '?'
    NO_SPACE_OP_QUESTION
    OP_BAR = '|'
    OP_PLUS = '+'
    OP_STAR = '*'
    OP_DOUBLE_SLASH = '//'
    OP_SLASH = '/'
    OP_BACKSLASH
    OP_PERCENT = '%'
    OP_CARET = '^'
    OP_GREATER_THAN_OR_EQ = '>='
    OP_GREATER_THAN = '>'
    OP_LESS_THAN_OR_EQ = '<='
    OP_BACK_ARROW = '<-'
    OP_LESS_THAN = '<'
    OP_BINARY_MINUS
    OP_UNARY_MINUS

    // dot family
    DOT = '.'
    DOUBLE_DOT = '..'
    TRIPLE_DOT = '...'
    DOT_STAR = '.*'
    DOT_INT
    DOT_LOWER_IDENT
    DOT_UPPER_IDENT
    NO_SPACE_DOT_INT
    NO_SPACE_DOT_LOWER_IDENT
    NO_SPACE_DOT_UPPER_IDENT

    // identifiers & literals
    LOWER_IDENT
    UPPER_IDENT
    INT
    FLOAT
    SINGLE_QUOTE
    UNDERSCORE = '_'
    NAMED_UNDERSCORE
    OPAQUE_NAME

    // strings
    STRING_START
    STRING_END
    STRING_PART
    MULTILINE_STRING_START
    OPEN_STRING_INTERPOLATION
    CLOSE_STRING_INTERPOLATION

    // trivia
    COMMENT

    // keywords (and/or are operators in Roc but kept as named tokens)
    KW_AND = 'and'
    KW_APP = 'app'
    KW_AS = 'as'
    KW_CRASH = 'crash'
    KW_DBG = 'dbg'
    KW_ELSE = 'else'
    KW_EXPECT = 'expect'
    KW_EXPOSES = 'exposes'
    KW_EXPOSING = 'exposing'
    KW_FOR = 'for'
    KW_GENERATES = 'generates'
    KW_HAS = 'has'
    KW_HOSTED = 'hosted'
    KW_IF = 'if'
    KW_IMPLEMENTS = 'implements'
    KW_IMPORT = 'import'
    KW_IMPORTS = 'imports'
    KW_IN = 'in'
    KW_INTERFACE = 'interface'
    KW_MATCH = 'match'
    KW_MODULE = 'module'
    KW_OR = 'or'
    KW_PACKAGE = 'package'
    KW_PACKAGES = 'packages'
    KW_PLATFORM = 'platform'
    KW_PROVIDES = 'provides'
    KW_REQUIRES = 'requires'
    KW_RETURN = 'return'
    KW_TARGETS = 'targets'
    KW_VAR = 'var'
    KW_WHERE = 'where'
    KW_WHILE = 'while'
    KW_WITH = 'with'
    KW_BREAK = 'break'
  ]

}

// A Roc file is an optional header followed by top-level items.
root ::= header? topLevelItem*

// TEMP: `throwaway` is the last-resort single-token mop-up from lexer bring-up;
// it retires with M4 (expressions). The `typeAnno` root arm is GONE — real
// type-declaration statements (below) now cover those inputs.
private topLevelItem ::= statement | throwaway

private statement ::= importStatement | valueAnnotation | typeDecl | valueDecl
private throwaway ::=
      LBRACE | RBRACE | LPAREN | NO_SPACE_LPAREN | RPAREN | LBRACK | RBRACK | COMMA
    | OP_ARROW | OP_FAT_ARROW | OP_PIZZA | OP_ASSIGN | OP_EQUALS | OP_COLON
    | OP_COLON_EQUAL | OP_DOUBLE_COLON | OP_NOT_EQUALS | OP_BANG | OP_AMPERSAND
    | OP_DOUBLE_QUESTION | OP_QUESTION | NO_SPACE_OP_QUESTION | OP_BAR | OP_PLUS
    | OP_STAR | OP_DOUBLE_SLASH | OP_SLASH | OP_BACKSLASH | OP_PERCENT | OP_CARET
    | OP_GREATER_THAN_OR_EQ | OP_GREATER_THAN | OP_LESS_THAN_OR_EQ | OP_BACK_ARROW
    | OP_LESS_THAN | OP_BINARY_MINUS | OP_UNARY_MINUS
    | DOT | DOUBLE_DOT | TRIPLE_DOT | DOT_STAR | DOT_INT | DOT_LOWER_IDENT
    | DOT_UPPER_IDENT | NO_SPACE_DOT_INT | NO_SPACE_DOT_LOWER_IDENT
    | NO_SPACE_DOT_UPPER_IDENT
    | LOWER_IDENT | UPPER_IDENT | INT | FLOAT | SINGLE_QUOTE | UNDERSCORE
    | NAMED_UNDERSCORE | OPAQUE_NAME
    | STRING_START | STRING_END | STRING_PART | MULTILINE_STRING_START
    | OPEN_STRING_INTERPOLATION | CLOSE_STRING_INTERPOLATION
    | COMMENT


// == headers ================================================
// Dispatched on a distinct leading keyword (app/module/package/hosted/platform),
// so the alternatives are first-token-disjoint and order is irrelevant
// platform header is difficult and uses many other primitives is at the bottom of this file
header ::= appHeader | moduleHeader | packageHeader | hostedHeader | platformHeader

appHeader     ::= KW_APP provides packages
moduleHeader  ::= KW_MODULE exposes
packageHeader ::= KW_PACKAGE exposes packages
hostedHeader  ::= KW_HOSTED exposes

provides ::= exposedList
exposes  ::= exposedList
private exposedList ::= LBRACK (exposedItem (COMMA exposedItem)* COMMA?)? RBRACK

exposedItem ::= LOWER_IDENT (KW_AS LOWER_IDENT)?
              | UPPER_IDENT (KW_AS UPPER_IDENT | DOT_STAR)?

// The brace-delimited packages block: `{ name: "path", pf: platform "path" }`
packages     ::= LBRACE (packageEntry (COMMA packageEntry)* COMMA?)? RBRACE
packageEntry ::= LOWER_IDENT OP_COLON KW_PLATFORM? string

string ::= STRING_START stringElement* STRING_END
private stringElement ::= STRING_PART | stringInterpolation
stringInterpolation ::= OPEN_STRING_INTERPOLATION CLOSE_STRING_INTERPOLATION // M1 stub: no inner expr yet

// == imports ================================================
// Two forms, dispatched on the token after `import`:
//   module import:  import pf.Stdout | import Json.Core | import json.Json.Utf8
//                          ... as Out | ... exposing [line!, write]
//   file import:    import "data.txt" as data : Str
importStatement ::= KW_IMPORT (fileImport | moduleImport)

private moduleImport ::= moduleName importAlias? importExposing?
moduleName ::= UPPER_IDENT  (NO_SPACE_DOT_UPPER_IDENT | DOT_UPPER_IDENT)*
             | LOWER_IDENT (NO_SPACE_DOT_UPPER_IDENT | DOT_UPPER_IDENT)+
importAlias    ::= KW_AS UPPER_IDENT
importExposing ::= KW_EXPOSING exposedList        // reuses the header's exposedList

// `import "path" as name : <type>`. Roc restricts the type to Str / List(U8),
// but that's a semantic check; syntactically any typeAnno is accepted here.
private fileImport ::= string KW_AS LOWER_IDENT OP_COLON typeAnno

// == type-declaration statements ============================
valueAnnotation ::= (LOWER_IDENT | NAMED_UNDERSCORE) OP_COLON typeAnno whereClause?

// `Name(a) : T` (alias) | `Name(a) := T` (nominal) | `Name(a) :: T` (opaque).

// Params are PARENTHESISED type vars (parseTypeIdent) — the old space-separated
typeDecl       ::= typeHeader (OP_COLON | OP_COLON_EQUAL | OP_DOUBLE_COLON) typeAnno whereClause?
typeHeader     ::= UPPER_IDENT typeHeaderArgs?
typeHeaderArgs ::= (NO_SPACE_LPAREN | LPAREN) (typeParam (COMMA typeParam)* COMMA?)? RPAREN
// A type parameter is the DECLARATION site of a type variable (uses appear as
// `typeReference`). Kept public so a later resolution phase can hang find-usages /
// rename / unused-param on it (PsiNamedElement) without re-shaping the grammar.
typeParam ::= LOWER_IDENT | NAMED_UNDERSCORE | UNDERSCORE

// `where [ clause, … ]` abilities constraints. A clause is a method
// (`a.method : Type`) or an alias (`a.Alias`, no colon). Method types reuse `typeAnno`
// (commonly a comma-arg function, e.g. `a, a -> Bool`). The reference rejects an empty
// `where []`, so at least one clause is required.
whereClause ::= KW_WHERE LBRACK whereClauseItem (COMMA whereClauseItem)* COMMA? RBRACK
private whereClauseItem ::= whereMethod | whereAlias
whereMethod ::= LOWER_IDENT (NO_SPACE_DOT_LOWER_IDENT | DOT_LOWER_IDENT) OP_COLON typeAnno
whereAlias  ::= LOWER_IDENT (NO_SPACE_DOT_UPPER_IDENT | DOT_UPPER_IDENT)

// == declarations (TEMP pattern harness) ====================
// Patterns aren't a top-level construct, so a destructuring value decl hosts them
// for testing. `exprStub` is atoms-only scaffolding until M4 (expressions) lands a
// real `expr`; at that point this becomes the genuine value/destructure decl.
valueDecl ::= patternNoAlts OP_ASSIGN exprStub
private exprStub ::= INT | FLOAT | LOWER_IDENT | UPPER_IDENT | string

// == patterns ===============================================
private pattern       ::= alternativesPattern | asPattern | patternPrimary
private patternNoAlts ::= asPattern | patternPrimary

// `a | b | c`
alternativesPattern ::= patternPrimary (OP_BAR patternPrimary)+
// postfix `p as name` — only a node when `as` is present.
asPattern ::= patternPrimary KW_AS LOWER_IDENT

// All first-sets are disjoint, so ordering is irrelevant and there is no
// intra-primary backtracking.
private patternPrimary ::= varPattern
                         | underscorePattern
                         | identPattern
                         | tagPattern
                         | literalPattern
                         | string
                         | listPattern
                         | recordPattern
                         | tuplePattern

identPattern      ::= LOWER_IDENT | NAMED_UNDERSCORE   // both are `.ident` in Roc
varPattern        ::= KW_VAR LOWER_IDENT               // mutable binder `var x`
underscorePattern ::= UNDERSCORE                       // `_`
literalPattern    ::= INT | FLOAT | SINGLE_QUOTE       // string literal reuses `string`

// `Ok`, `Json.Ok`, `Pair(x, y)`. Qualifier chain = lexer dotted-upper tokens
tagPattern     ::= UPPER_IDENT NO_SPACE_DOT_UPPER_IDENT* tagPatternArgs?
tagPatternArgs ::= NO_SPACE_LPAREN (pattern (COMMA pattern)* COMMA?)? RPAREN

// `[a, b]`, `[1, 2, .. as rest]`, `[..]`. List rest is `.. as name` (new syntax).
listPattern             ::= LBRACK (listPatternElem (COMMA listPatternElem)* COMMA?)? RBRACK
private listPatternElem ::= listRestPattern | pattern
listRestPattern         ::= DOUBLE_DOT (KW_AS LOWER_IDENT)?

// `{ name, age }`, `{ name: n }`, `{ x, ..rest }`. NB record rest is `..name`
// directly (no `as`), unlike list rest.
recordPattern      ::= LBRACE (recordPatternField (COMMA recordPatternField)* COMMA?)? RBRACE
recordPatternField ::= DOUBLE_DOT LOWER_IDENT?
                     | LOWER_IDENT (OP_COLON pattern)?

// `(a, b)`, `(a)`. A standalone '(' may be spaced or no-space.
tuplePattern ::= (NO_SPACE_LPAREN | LPAREN) (pattern (COMMA pattern)* COMMA?)? RPAREN

// == type annotations =======================================
// Faithful to parseTypeAnno in the Zig reference (roc-lang/src/parse/Parser.zig).
//
// The arrow function is the lowest-precedence type; its argument list may be a
// bare comma list (`Str, Str -> Str`). `functionType` REQUIRES a trailing arrow,
// so for a plain type it backtracks to `primaryType`. That same backtracking is
// what lets a record field type stop at the next field (`{ a: Str, b: U64 }`)
// and an apply arg stop at the next arg (`Dict(Str, List(U64))`) — the comma
// list is only kept when an arrow actually follows.
//
// KNOWN LIMITATION: an unparenthesized arrow used as a NON-final argument inside
// `( )` / apply args (e.g. `Dict(k, v -> w)`) is grabbed as one comma-grouped
// function rather than two args. Roc flips comma/arrow precedence per-context via
// a lookahead flag; we don't yet. Rare in practice — parenthesize for now.
// typeAnno / primaryType are dispatch-only (private) so the concrete type node
// (functionType, typeReference, recordType, …) attaches directly, with no
// redundant wrapper — same idea as `header`.
private typeAnno ::= functionType | primaryType

functionType ::= typeFnArgs (OP_ARROW | OP_FAT_ARROW) typeAnno
private typeFnArgs ::= primaryType (COMMA primaryType)*

private primaryType ::= typeReference
                      | tupleType
                      | recordType
                      | tagUnionType
                      | inferredType
                      | inferredTypeVar

// Str, Bool, Foo.Bar, json.Mod.Type, List(a), Dict(k, v).
// Qualification is built from the no-space dotted tokens the lexer emits, e.g.
// `Json.Decoder` -> UPPER_IDENT NO_SPACE_DOT_UPPER_IDENT. Application requires a
// no-space '(' (NO_SPACE_LPAREN), matching `List(a)` but not `List (a)`.
typeReference ::= typeName typeArguments?
private typeName ::= (UPPER_IDENT | LOWER_IDENT) qualifierSegment*
private qualifierSegment ::= NO_SPACE_DOT_UPPER_IDENT | NO_SPACE_DOT_LOWER_IDENT
typeArguments ::= NO_SPACE_LPAREN (typeAnno (COMMA typeAnno)* COMMA?)? RPAREN

// (a), (a, b), (a -> b). A standalone '(' may be no-space or spaced.
tupleType ::= (NO_SPACE_LPAREN | LPAREN) (typeAnno (COMMA typeAnno)* COMMA?)? RPAREN

// { name: Type, ..ext } — `..` / `..rest` extension must be last.
recordType ::= LBRACE recordTypeBody? RBRACE
private recordTypeBody ::= recordTypeField (COMMA recordTypeField)* (COMMA recordTypeExt)? COMMA?
                         | recordTypeExt
recordTypeField ::= LOWER_IDENT OP_COLON typeAnno
recordTypeExt ::= DOUBLE_DOT (LOWER_IDENT | NAMED_UNDERSCORE)?

// [Ok(a), Err(b), ..ext] — open-union extension must be last.
tagUnionType ::= LBRACK tagUnionBody? RBRACK
private tagUnionBody ::= tagUnionMember (COMMA tagUnionMember)* (COMMA tagUnionExt)? COMMA?
                       | tagUnionExt
tagUnionMember ::= UPPER_IDENT typeArguments?
tagUnionExt ::= DOUBLE_DOT (LOWER_IDENT | NAMED_UNDERSCORE)?

inferredType    ::= UNDERSCORE        // _
inferredTypeVar ::= NAMED_UNDERSCORE  // _name

// == platform header ========================================
// Shape: platform "name" requires {…} exposes […] packages {…} provides {…} [targets:…]
platformHeader ::= KW_PLATFORM string
                   KW_REQUIRES platformRequires
                   KW_EXPOSES  exposes
                   KW_PACKAGES packages
                   KW_PROVIDES platformProvides
                   platformTargets?

platformRequires ::= LBRACE RBRACE LBRACE requiresEntries? RBRACE
                   | LBRACE requiresEntries? RBRACE
private requiresEntries ::= requiresEntry (COMMA requiresEntry)* COMMA?
// `main! : Type`, optionally prefixed by a for-clause `[Model : model] for`.
requiresEntry     ::= requiresForClause? LOWER_IDENT OP_COLON typeAnno
requiresForClause ::= LBRACK requiresForAlias (COMMA requiresForAlias)* RBRACK KW_FOR
requiresForAlias  ::= UPPER_IDENT OP_COLON LOWER_IDENT

// `provides { name: <expr>, … }` — record-style, unlike the app header's `[ … ]`
// provides. Values are expressions (always a string path in practice); `exprStub`
// is the shared M4 placeholder.
platformProvides      ::= LBRACE (platformProvidesField (COMMA platformProvidesField)* COMMA?)? RBRACE
platformProvidesField ::= LOWER_IDENT (OP_COLON exprStub)?

// optional `targets: { files: "…", exe: { x64mac: ["libhost.a", app], … }, … }`.
// A target field's value is a string (files path) or a link-type block; a link
// entry maps a triple name to a bracketed file list of strings / idents / `app`.
platformTargets ::= KW_TARGETS OP_COLON LBRACE (targetsField (COMMA targetsField)* COMMA?)? RBRACE
targetsField    ::= LOWER_IDENT OP_COLON (string | targetLinkType)
targetLinkType  ::= LBRACE (targetLinkEntry (COMMA targetLinkEntry)* COMMA?)? RBRACE
targetLinkEntry ::= LOWER_IDENT OP_COLON LBRACK (targetFile (COMMA targetFile)* COMMA?)? RBRACK
targetFile      ::= string | LOWER_IDENT | KW_APP
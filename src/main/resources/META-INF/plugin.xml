<idea-plugin>
    <id>org.roc.community.intellij-roc</id>

    <name>Roc</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.yourcompany.com">YourCompany</vendor>

    <description><![CDATA[
        Adds support ofr the Roc programming language in IntelliJ IDEA.
        ]]></description>

    <depends>com.intellij.modules.lsp</depends>

    <resource-bundle>messages.RocMessageBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Roc" implementationClass="org.roc.community.roc.RocFileType" fieldName="INSTANCE" language="Roc" extensions="roc"/>
        <lang.parserDefinition language="Roc" implementationClass="org.roc.community.roc.parser.RocParserDefinition"/>
        <lang.syntaxHighlighter language="Roc" implementationClass="org.roc.community.roc.colors.RocHighlighter"/>
        <colorSettingsPage implementation="org.roc.community.roc.colors.RocColorsPage"/>
        <platform.lsp.serverSupportProvider implementation="org.roc.community.roc.lsp.RocLspServerSupportProvider" />
        <projectConfigurable
                parentId="language"
                instance="org.roc.community.roc.settings.RocSettingsConfigurable"
                id="Settings.Roc"
                nonDefaultProject="true"
                key="roc.settings.name"
                bundle="messages.RocMessageBundle"
        />
    </extensions>

</idea-plugin>
